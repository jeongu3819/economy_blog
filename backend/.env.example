# ─── 서버 설정 ───
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─── Playwright 설정 ───
# 자동화 전용 프로필 디렉토리 (최초 1회 수동 로그인 필요)
PLAYWRIGHT_USER_DATA_DIR=./playwright-session

# true로 설정하면 브라우저 창 없이 실행 (디버깅 시 false 권장)
AUTOMATION_HEADLESS=false

# ─── ChatGPT URL ───
CHATGPT_BASE_URL=https://chatgpt.com/
CHATGPT_GPT_URL=https://chatgpt.com/g/g-67f26f292d908191af9814f781eff794-newstock

# ─── StockTitan ───
STOCKTITAN_BASE_URL=https://stocktitan.net

# ─── 타임아웃 ───
# 전체 요청 타임아웃 (밀리초)
REQUEST_TIMEOUT=120000

# 응답 안정화 판정 시간 (초) — 이 기간 동안 텍스트 변화가 없으면 완료로 판정
RESPONSE_STABLE_SECONDS=3
